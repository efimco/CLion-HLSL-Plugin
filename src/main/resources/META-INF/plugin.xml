<idea-plugin>
    <id>com.hlsl.plugin</id>
    <name>HLSL Language Support</name>
    <vendor>DOCC</vendor>
    <description><![CDATA[
        Syntax highlighting and DXC validation for HLSL (High Level Shading Language) files.
        Supports .hlsl and .hlsli file extensions by default.
        Additional extensions (.fx, .fxh, .vsh, .psh, .gsh, .csh, etc.) can be added via Settings > Editor > File Types > HLSL.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
                name="HLSL File"
                implementationClass="com.hlsl.HlslFileType"
                fieldName="INSTANCE"
                language="HLSL"
                extensions="hlsl;hlsli"/>

        <lang.parserDefinition
                language="HLSL"
                implementationClass="com.hlsl.parser.HlslParserDefinition"/>

        <lang.syntaxHighlighterFactory
                language="HLSL"
                implementationClass="com.hlsl.highlighting.HlslSyntaxHighlighterFactory"/>

        <colorSettingsPage
                implementation="com.hlsl.highlighting.HlslColorSettingsPage"/>

        <lang.commenter
                language="HLSL"
                implementationClass="com.hlsl.HlslCommenter"/>

        <lang.braceMatcher
                language="HLSL"
                implementationClass="com.hlsl.HlslBraceMatcher"/>

        <lang.foldingBuilder
                language="HLSL"
                implementationClass="com.hlsl.folding.HlslFoldingBuilder"/>

        <completion.contributor
                language="HLSL"
                implementationClass="com.hlsl.completion.HlslCompletionContributor"/>

        <psi.referenceContributor
                language="HLSL"
                implementation="com.hlsl.navigation.HlslReferenceContributor"/>

        <gotoDeclarationHandler
                implementation="com.hlsl.navigation.HlslGotoDeclarationHandler"/>

        <annotator
                language="HLSL"
                implementationClass="com.hlsl.highlighting.HlslStructNameAnnotator"/>

        <externalAnnotator
                language="HLSL"
                implementationClass="com.hlsl.validation.HlslDxcAnnotator"/>

        <applicationConfigurable
                parentId="tools"
                instance="com.hlsl.validation.HlslDxcConfigurable"
                id="com.hlsl.validation.HlslDxcConfigurable"
                displayName="HLSL / DXC"/>

        <applicationService
                serviceImplementation="com.hlsl.validation.HlslDxcSettings"/>

        <intentionAction>
            <language>HLSL</language>
            <className>com.hlsl.intentions.HlslAddDxcPragmasIntention</className>
            <category>HLSL</category>
        </intentionAction>

        <formattingService
                implementation="com.hlsl.formatting.HlslClangFormatService"/>

        <applicationService
                serviceImplementation="com.hlsl.formatting.HlslClangFormatSettings"/>

        <applicationConfigurable
                parentId="tools"
                instance="com.hlsl.formatting.HlslClangFormatConfigurable"
                id="com.hlsl.formatting.HlslClangFormatConfigurable"
                displayName="HLSL / clang-format"/>

        <notificationGroup
                id="HLSL clang-format"
                displayType="BALLOON"/>
    </extensions>
</idea-plugin>
